---
// 订阅组件：可通过 Props 自定义标题、中文说明、输入框占位和按钮文案。
// 适合放在营销页或内容页底部，用于收集用户邮箱订阅意向。
import Button from './Button.astro';

// 组件 Props：允许调用方覆盖默认文案，提升订阅模块在不同页面的复用性。
interface Props {
  heading?: string;
  headingZh?: string;
  placeholder?: string;
  ctaText?: string;
}

// 解构 Props 并设置默认值：没有传参时仍显示完整可用的订阅表单。
const {
  heading = 'Join LIMOVA Club',
  headingZh = '订阅展示最新动向和重要优惠',
  placeholder = 'Enter your email',
  ctaText = 'Subscribe'
} = Astro.props;
---

<!-- 订阅区块：用于收集用户邮箱，当前表单只负责前端展示和原生必填校验。 -->
<section class="py-20 px-6 bg-cream">
  <div class="max-w-2xl mx-auto">
    <div class="flex items-center gap-4 mb-8">
      <svg class="w-8 h-8 text-purple" fill="currentColor" viewBox="0 0 24 24">
        <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
      </svg>
      <div>
        <h3 class="text-xl font-bold text-gray-900">{heading}</h3>
        <p class="text-sm text-gray-600">{headingZh}</p>
      </div>
    </div>

    <form class="flex gap-2">
      <input
        type="email"
        placeholder={placeholder}
        required
        class="flex-1 px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:border-purple"
      />
      <button type="submit" class="btn-primary">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </button>
    </form>
  </div>
</section>
