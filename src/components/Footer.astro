---
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-content">
      <div class="footer-section">
        <h4>LIMOVA</h4>
      </div>

      <div class="footer-section">
        <a href="#privacy">Privacy Policy</a>
        <a href="#terms">Terms of Service</a>
        <a href="#shipping">Shipping Info</a>
        <a href="#contact">Contact Us</a>
      </div>
    </div>

    <div class="footer-social">
      <a href="#instagram" aria-label="Instagram">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5" fill="none" stroke="currentColor" stroke-width="2"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37Z" fill="currentColor"/>
          <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor"/>
        </svg>
      </a>
      <a href="#tiktok" aria-label="TikTok">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.68v13.67a2.4 2.4 0 0 1-2.4 2.4 2.4 2.4 0 0 1-2.4-2.4 2.4 2.4 0 0 1 2.4-2.4c.34 0 .67.05.98.14V9.58a5.8 5.8 0 0 0-.98-.08c-3.3 0-6 2.7-6 6s2.7 6 6 6 6-2.7 6-6V9.91a7.1 7.1 0 0 0 4.77 1.74v-3.6a4.9 4.9 0 0 1-.98.08z" fill="currentColor"/>
        </svg>
      </a>
      <a href="#pinterest" aria-label="Pinterest">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2"/>
          <circle cx="12" cy="12" r="3" fill="currentColor"/>
        </svg>
      </a>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; 2026 LIMOVA. All Rights Reserved.</p>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--light-bg);
    border-top: 1px solid #e0e0e0;
    padding: 3rem 2rem 2rem;
  }

  .footer-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .footer-content {
    display: flex;
    gap: 4rem;
  }

  .footer-section {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .footer-section h4 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .footer-section a {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .footer-section a:hover {
    color: var(--primary-purple);
  }

  .footer-social {
    display: flex;
    gap: 1.5rem;
  }

  .footer-social a {
    color: var(--dark-text);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer-social a:hover {
    color: var(--primary-purple);
  }

  .footer-bottom {
    text-align: center;
    border-top: 1px solid #e0e0e0;
    padding-top: 2rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .footer-container {
      flex-direction: column;
      gap: 2rem;
    }

    .footer-content {
      flex-direction: column;
      gap: 2rem;
      width: 100%;
    }

    .footer-social {
      width: 100%;
      justify-content: center;
    }
  }
</style>
