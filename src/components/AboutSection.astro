---
// “关于我们”区块：用于展示品牌理念、订阅入口和信任徽章。
// 当前组件没有接收 Props，所有文案与占位视觉都在组件内静态维护。
---

<!-- 关于我们区块：将品牌故事、订阅表单和服务承诺集中展示。 -->
<section class="about">
  <div class="about-container">
    <!-- 品牌文案：用中英混排强化 LIMOVA 的设计态度和情绪价值。 -->
    <div class="about-content">
      <h2>About LIMOVA</h2>
      <p class="subtitle">关于我们</p>
      <p class="description">
        是创意的、我们不只是做鞋<br>
        而是在创造时刻。LIMOVA<br>
        用设计承诺品质、用态度<br>
        诠释自在。只有懂美的人，<br>
        才能感受我们的用心。
      </p>
      <p class="signature">LIMOVA Team ❤️</p>
    </div>

    <div class="about-image"></div>

    <!-- 订阅卡片：放在关于区块内部，方便被品牌故事触达的用户留下邮箱。 -->
    <div class="newsletter">
      <h3>Let's stay in touch!</h3>
      <p>订阅我们的最新消息</p>
      <form class="email-form">
        <input type="email" placeholder="Enter your email" required>
        <button type="submit">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
      </form>
    </div>

    <!-- 信任徽章：用三个短信息降低用户对配送、支付和退换货的顾虑。 -->
    <div class="trust-badges">
      <div class="badge">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
        </svg>
        <p>Worldwide<br>Shopping</p>
      </div>
      <div class="badge">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
        </svg>
        <p>Secure<br>Payment</p>
      </div>
      <div class="badge">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2">
          <path d="M9 11l3 3L22 4"></path>
          <path d="M20 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h11"></path>
        </svg>
        <p>Easy<br>Returns</p>
      </div>
    </div>
  </div>
</section>

<style>
  /* About 样式：使用紫色渐变背景、装饰波形和网格布局营造品牌氛围。 */
  .about {
    background: linear-gradient(135deg, #b89ddb 0%, #d4b5e8 100%);
    color: white;
    padding: 5rem 2rem;
    position: relative;
    overflow: hidden;
  }

  .about::before {
    content: '';
    position: absolute;
    top: -100px;
    left: 0;
    right: 0;
    height: 200px;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120"><path d="M0,50 Q300,100 600,50 T1200,50 L1200,0 L0,0 Z" fill="rgba(255,255,255,0.1)"></path></svg>');
    background-repeat: repeat-x;
    opacity: 0.3;
  }

  .about-container {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
    position: relative;
    z-index: 1;
  }

  .about-content h2 {
    font-size: 2.2rem;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
    opacity: 0.9;
  }

  .description {
    font-size: 0.95rem;
    line-height: 1.8;
    margin-bottom: 2rem;
    opacity: 0.95;
  }

  .signature {
    font-size: 0.9rem;
    font-style: italic;
  }

  .about-image {
    width: 100%;
    height: 400px;
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    grid-column: 2;
    grid-row: 1 / 4;
  }

  .newsletter {
    grid-column: 2;
    background-color: rgba(255, 255, 255, 0.95);
    color: var(--dark-text);
    padding: 2rem;
    border-radius: 16px;
    margin-top: 2rem;
  }

  .newsletter h3 {
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
    color: var(--dark-text);
  }

  .newsletter p {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .email-form {
    display: flex;
    gap: 0.5rem;
  }

  .email-form input {
    flex: 1;
    padding: 0.8rem 1rem;
    border: none;
    border-radius: 50px;
    font-size: 0.9rem;
    background-color: #f5f5f5;
  }

  .email-form input::placeholder {
    color: #ccc;
  }

  .email-form button {
    background-color: var(--primary-purple);
    color: white;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .email-form button:hover {
    background-color: #a682c5;
  }

  .trust-badges {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 3rem;
    padding-top: 3rem;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
  }

  .badge {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
  }

  .badge svg {
    width: 40px;
    height: 40px;
  }

  .badge p {
    font-size: 0.85rem;
    line-height: 1.4;
  }

  @media (max-width: 1024px) {
    .about-container {
      grid-template-columns: 1fr;
    }

    .about-image {
      grid-column: 1;
      grid-row: 2;
      height: 300px;
    }

    .newsletter {
      grid-column: 1;
      grid-row: 3;
    }

    .trust-badges {
      grid-column: 1;
    }
  }

  @media (max-width: 768px) {
    .about {
      padding: 3rem 1rem;
    }

    .about-content h2 {
      font-size: 1.6rem;
    }

    .trust-badges {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
</style>
