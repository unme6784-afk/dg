---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="LIMOVA - Step into Curves. Ultra-lightweight, comfortable, eco-friendly footwear." />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <style is:global>
      html {
        scroll-behavior: smooth;
      }
      body {
        overflow-x: hidden;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
